{
  "name": "auto-video-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "start": "tsx src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "test:accounts": "node --import tsx --test tests/account-matrix.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "chokidar": "^4.0.3",
    "clipboardy": "^4.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "image-size": "^2.0.2",
    "lucide-react": "^0.562.0",
    "multer": "^2.1.1",
    "open": "^10.2.0",
    "openai": "^6.10.0",
    "playwright-core": "^1.57.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
